# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Admin Configuration (comma-separated list of Telegram IDs)
ADMIN_IDS=123456789,987654321

# Database (for Docker use 'postgres', for local use 'localhost')
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=buyout_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Redis (for Docker use 'redis', for local use 'localhost')
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
SHEET1_NAME=Лис1
SHEET2_NAME=Лис2

# Analytics
ANALYTICS_UPDATE_INTERVAL=300

# Bot Configuration
BOT_LANGUAGE=ru
DEBUG=False
